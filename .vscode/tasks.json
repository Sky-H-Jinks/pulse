{
  // Run via Ctrl+Shift+P → "Tasks: Run Task".
  // Each dev task gets its own terminal panel so logs don't interleave.
  "version": "2.0.0",
  "tasks": [
    {
      "label": "infra: postgres up",
      "type": "shell",
      "command": "docker compose up -d postgres",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "dev: control-plane (C#)",
      "type": "shell",
      "command": "dotnet watch --project src/ControlPlane.Api",
      "options": { "cwd": "${workspaceFolder}/control-plane" },
      "isBackground": true,
      "presentation": { "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "dev: dashboard (React)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/dashboard" },
      "isBackground": true,
      "presentation": { "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "dev: ingest (Rust)",
      "type": "shell",
      "command": "cargo run",
      "options": { "cwd": "${workspaceFolder}/ingest" },
      "isBackground": true,
      "presentation": { "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "dev: intelligence (Python)",
      "type": "shell",
      "command": "uv run uvicorn app.main:app --reload --port 8000",
      "options": { "cwd": "${workspaceFolder}/intelligence" },
      "isBackground": true,
      "presentation": { "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      // One keypress starts everything Phase 1 needs.
      // Extend dependsOn as later phases land.
      "label": "dev: phase 1 stack",
      "dependsOn": [
        "infra: postgres up",
        "dev: control-plane (C#)",
        "dev: dashboard (React)"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
